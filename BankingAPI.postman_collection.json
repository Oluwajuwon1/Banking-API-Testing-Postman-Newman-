    {
      "name": "Update Sender & Receiver  Balance",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const senderbalnew =  Number(pm.environment.get('Sender_Bal'));\r",
              "const receiverbalnew = Number(pm.environment.get('Receiver_Bal'));\r",
              "const amount = Number(pm.environment.get('transferamount'));\r",
              "\r",
              "if (amount > senderbalnew) {\r",
              "    throw new Error ('Insufficient Balance for transfer');\r",
              "}\r",
              "\r",
              "const newsender = senderbalnew -amount;\r",
              "const newreceiver= receiverbalnew + amount;\r",
              "pm.environment.set('Sender_Bal', newsender);\r",
              "pm.environment.set('Receiver_Bal', newreceiver);\r",
              "pm.environment.set('current_timestamp', new Date().toISOString());\r",
              "\r",
              "pm.test(\"Amount should be valid number\", () => {\r",
              "     pm.expect(amount).to.not.be.NaN;\r",
              "});\r",
              "pm.test(\"Sender has sufficient balance\", () => {\r",
              "    pm.expect(amount).to.be.at.most(senderbalnew);\r",
              "});\r",
              "pm.test('sender balance updated successfully', ()=> {\r",
              "    pm.expect(newsender).to.equal(senderbalnew - amount);\r",
              "});\r",
              "\r",
              "pm.test('sender balance should not be negative', ()=>{\r",
              "    pm.expect(newsender).to.be.at.least(0);\r",
              "});\r",
              "pm.test('receiver balance updated successfully', ()=> {\r",
              "    pm.expect(newreceiver).to.equal(receiverbalnew + amount);\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
