    {
      "name": "Successful Login Authentication",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const users = pm.response.json();\r",
              "\r",
              "const Email = pm.environment.get('ValidEmail');\r",
              "const Password = pm.environment.get('ValidPassword');\r",
              "\r",
              "const matchedUser = users.find(user => \r",
              "    user.Email === Email && user.Password === Password\r",
              ");\r",
              "\r",
              "if (matchedUser) {\r",
              "    pm.environment.set(\"login_status\", \"success\");\r",
              "    pm.environment.set(\"userId\", matchedUser.id);\r",
              "} else {\r",
              "    pm.environment.set(\"login_status\", \"failed\");\r",
              "}\r",
              "\r",
              "pm.test(\"User should be authenticated successfully\", () => {\r",
              "    pm.expect(matchedUser).to.not.be.undefined;\r",
              "});\r",
              "if (matchedUser) {\r",
              "    pm.environment.set(\"login_status\", \"success\");\r",
              "    pm.environment.set(\"userId\", matchedUser.id);\r",
              "}\r",
              "pm.test(\"Status code is 200\", ()=> {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('matched id should be 1'), ()=> {\r",
              "    pm.expect(matchedUser.id).to.eql(1);\r",
              "}\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
