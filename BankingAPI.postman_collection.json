    {
      "name": "Create Transactions Record",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect\r",
              "});\r",
              "\r",
              "pm.test('Status of the transaction should be success', ()=>{\r",
              "    pm.expect(pm.response.json().Status).to.eql('success');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const amount = Number(pm.globals.get(\"transferamount\"));\r",
              "const senderBal = Number(pm.environment.get(\"Sender_Bal\"));\r",
              "\r",
              "\r",
              "let status = \"success\";\r",
              "\r",
              "if (amount > senderBal) {\r",
              "    status = \"failed\";\r",
              "}\r",
              "\r",
              "const timestamp = new Date().toISOString();\r",
              "\r",
              "pm.environment.set(\"calculated_status\", status);\r",
              "pm.environment.set(\"calculated_timestamp\", timestamp);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"FromAccount\": \"{{sender_id}}\",\r\n  \"ToAccount\": \"{{receiver_id}}\",\r\n  \"Amount\": \"{{transferamount}}\",\r\n  \"Type\": \"transfer\",\r\n  \"Status\": \"{{calculated_status}}\",\r\n  \"Timestamp\": \"{{calculated_timestamp}}\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
